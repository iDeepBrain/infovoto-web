# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:2300
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Gateway URL (internal Docker network in prod, localhost in dev)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:2080
# Server-only gateway URL (for API route proxy — not exposed to browser)
GATEWAY_URL=http://localhost:2080
# API Key for gateway auth (server-side only — NEVER use NEXT_PUBLIC_ prefix)
GATEWAY_API_KEY_WEB=

# Google Analytics 4 (optional — get from Google Analytics console)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Admin email — server-only, never sent to browser (for dashboard access)
ADMIN_EMAIL=your-admin-email@gmail.com
