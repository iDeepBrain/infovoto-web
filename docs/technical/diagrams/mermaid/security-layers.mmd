flowchart TD
    U[Usuario escribe mensaje] --> FE

    subgraph FE[Frontend - Browser]
        F1[maxLength: 1000 chars]
        F2[Input sanitization]
        F3[isTokenExpired check]
    end

    FE --> |POST /api/chat| PROXY

    subgraph PROXY[Next.js Server Proxy]
        P1[1. NextAuth session check]
        P2[2. Rate limit: 30/hora]
        P3[3. Input validation: tipo + largo]
        P4[4. Prompt injection: 16 patterns]
        P5[5. X-API-Key injection]
        P6[6. Timeout: 20s]

        P1 --> |No session| R401[401 Not authenticated]
        P1 --> |OK| P2
        P2 --> |Exceeded| R429[429 Rate limit]
        P2 --> |OK| P3
        P3 --> |Invalid| R400[400 Bad request]
        P3 --> |OK| P4
        P4 --> |Detected| RBLOCK[200 Solo info electoral]
        P4 --> |Clean| P5
        P5 --> P6
    end

    P6 --> |Authorization: Bearer + X-API-Key| GW

    subgraph GW[Gateway]
        G1[Valida X-API-Key]
        G2[Valida Bearer token]
        G3[Agent procesa con Gemini]
        G4[Output filter + sanitización]
    end

    GW --> |ChatResponse| PROXY
    PROXY --> |JSON| FE

    subgraph HEADERS[Security Headers - next.config.mjs]
        H1[CSP: script-src self]
        H2[X-Frame-Options: DENY]
        H3[X-Content-Type-Options: nosniff]
        H4[CORS: solo tu dominio]
        H5[Permissions-Policy: sin cámara/mic]
    end

    style R401 fill:#ef4444,color:#fff
    style R429 fill:#f59e0b,color:#000
    style R400 fill:#ef4444,color:#fff
    style RBLOCK fill:#22c55e,color:#fff
    style PROXY fill:#1e293b,color:#fff
    style GW fill:#111827,color:#fff
