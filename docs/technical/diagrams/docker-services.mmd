graph LR
    subgraph DOCKER[Docker Compose — infovoto]
        WEB[Web<br/>:2300→3000<br/>Next.js 14]
        GW[Gateway<br/>:2080→8080<br/>FastAPI + Gemini]
        MCP[infovoto-mcp<br/>:2900→8080<br/>5 MCPs — FastMCP]
        PG[(PostgreSQL<br/>:2432→5432)]
        RD[(Redis<br/>:2379→6379<br/>rate limit + cache)]
        CH[(ChromaDB<br/>ONNX embeddings<br/>local en MCP)]
    end

    BROWSER[Browser<br/>localhost:2300] --> WEB
    WEB --> |/api/chat proxy<br/>Bearer + X-API-Key| GW
    GW --> |MCP tools/call| MCP
    GW --> |asyncpg SQL| PG
    GW --> |session + rate limit| RD
    MCP --> |SQL queries| PG
    MCP --> |vector search| CH

    subgraph EXTERNAL[Servicios Externos]
        GOOGLE[Google OAuth<br/>id_token verify]
        GEMINI[Gemini 2.0 Flash<br/>agent LLM]
    end

    WEB --> |NextAuth signIn| GOOGLE
    GW --> |token verify| GOOGLE
    GW --> |agent calls| GEMINI

    subgraph HEALTH[Health Checks]
        H1[PG: pg_isready]
        H2[Redis: redis-cli ping]
        H3[MCP: GET /perfiles/health]
        H4[GW: GET /health]
        H5[Web: GET /]
    end

    style WEB fill:#f59e0b,color:#000
    style GW fill:#3b82f6,color:#fff
    style MCP fill:#22c55e,color:#fff
    style PG fill:#8b5cf6,color:#fff
    style RD fill:#ef4444,color:#fff
    style CH fill:#06b6d4,color:#fff
